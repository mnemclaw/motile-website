---
// HowItWorks: three-step onboarding

const steps = [
  {
    number: "01",
    title: "Open the editor",
    description: "Visit your Motile page and click Edit — the visual editor appears inline, right on the page. No admin panel, no separate login.",
  },
  {
    number: "02",
    title: "Pick a theme and make it yours",
    description: "Choose from six design-forward themes, drag in your links and bio, and customise colours and typography in real time.",
  },
  {
    number: "03",
    title: "Share your link",
    description: "Your page lives at your domain, loads in under a second, and belongs to you — no tracking, no lock-in, no recurring fees.",
  },
];
---

<section id="how-it-works" class="py-24 bg-white px-4">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">
        Up and running in minutes.
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Self-hosting sounds harder than it is. Three steps and you have a beautiful, animated link page that's entirely yours.
      </p>
    </div>

    <div class="space-y-12">
      {steps.map((step) => (
        <div class="flex gap-8 items-start">
          <div class="text-5xl font-bold text-indigo-100 min-w-[5rem] text-right select-none">
            {step.number}
          </div>
          <div class="pt-2">
            <h3 class="text-2xl font-semibold text-slate-900 mb-2">{step.title}</h3>
            <p class="text-slate-600 text-lg">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
