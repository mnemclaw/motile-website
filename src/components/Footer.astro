---
// Footer: brand, navigation, legal
---

<footer class="bg-slate-900 text-slate-400 py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="text-white font-bold text-xl mb-3">
          Motile
        </div>
        <p class="text-sm">
          Self-hosted animated link-in-bio pages.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-white font-semibold mb-3">Product</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#themes" class="hover:text-white transition-colors">Themes</a></li>
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a></li>
        </ul>
      </div>

      <!-- Open Source -->
      <div>
        <h4 class="text-white font-semibold mb-3">Open Source</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com/mnemclaw/motile" class="hover:text-white transition-colors">GitHub</a></li>
          <li><a href="https://github.com/mnemclaw/motile/issues" class="hover:text-white transition-colors">Issues</a></li>
          <li><a href="https://github.com/mnemclaw/motile/blob/main/LICENSE" class="hover:text-white transition-colors">MIT License</a></li>
        </ul>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-white font-semibold mb-3">Jump in</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://mnemclaw.github.io/motile/" class="hover:text-white transition-colors">Open Editor</a></li>
          <li><a href="https://github.com/mnemclaw/motile" class="hover:text-white transition-colors">GitHub</a></li>
          <li><a href="/" class="hover:text-white transition-colors">Motile</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8 text-sm text-center">
      &copy; 2026 Motile — MIT License
    </div>
  </div>
</footer>
