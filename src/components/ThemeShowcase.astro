---
// ThemeShowcase: six curated themes

const themes = [
  {
    name: "Minimal",
    description: "Clean whitespace, precise typography, zero decoration — for people who let the work speak.",
  },
  {
    name: "Glass",
    description: "Frosted-glass cards, backdrop blur, vibrant accents — depth without clutter.",
  },
  {
    name: "Neon",
    description: "Near-black canvas, electric colour, glow effects — cyberpunk done with restraint.",
  },
  {
    name: "Retro",
    description: "Warm palette, serif headings, bold shadows — nostalgia with modern proportions.",
  },
  {
    name: "Dark Elegance",
    description: "Charcoal and gold, wide letter-spacing, editorial silence — premium without trying.",
  },
  {
    name: "Gradient",
    description: "Vivid multi-stop gradients, bold colour blocking, white text — energy you can feel.",
  },
];
---

<section id="themes" class="py-24 bg-slate-50 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">
        Six themes, built to impress.
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Each theme is a complete design system — consistent spacing, typography, and colour tokens. Switch between them live in the editor.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {themes.map((theme) => (
        <div class="p-6 rounded-2xl bg-white border border-slate-200 hover:border-indigo-300 hover:shadow-md transition-all">
          <h3 class="text-lg font-semibold text-slate-900 mb-1">{theme.name}</h3>
          <p class="text-slate-500 text-sm">{theme.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
